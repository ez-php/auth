{
  "name": "ez-php/auth",
  "version": "1.0.0",
  "description": "Authentication module for the ez-php framework — session and token-based auth with a flexible user provider interface",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["auth", "authentication", "php", "framework", "ez-php"],
  "homepage": "https://github.com/ez-php/auth",
  "support": {
    "issues": "https://github.com/ez-php/auth/issues",
    "source": "https://github.com/ez-php/auth"
  },
  "require": {
    "php": "^8.5",
    "ez-php/contracts": "0.*",
    "ez-php/http": "0.*",
    "ez-php/rate-limiter": "0.*"
  },
  "require-dev": {
    "ez-php/docker": "0.*",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "ez-php/testing-application": "0.*"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Auth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
